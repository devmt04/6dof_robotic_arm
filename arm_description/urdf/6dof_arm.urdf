    <!-- Joints -->
    <joint name="base_joint" type="revolute">
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <parent link="base"/>
        <child link="base_link"/>
        <axis xyz="0 0 1"/>
        <limit
            lower="-3.14159265359"
            upper="3.14159265359"
            effort="50"
            velocity="2.0"/>
    </joint>

    <joint name="base_link1_joint" type="fixed">
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="link_1"/>
    </joint>

    <joint name="link1_link2_joint" type="revolute">
